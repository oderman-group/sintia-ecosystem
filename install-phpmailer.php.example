<?php
/**
 * Script de instalación manual de PHPMailer
 * 
 * INSTRUCCIONES:
 * 1. Copia este archivo a install-phpmailer.php en el servidor
 * 2. Ejecuta desde el navegador: https://sintia.co/sintia/install-phpmailer.php
 * 3. Elimina install-phpmailer.php después de usar (seguridad)
 * 
 * Este script descarga PHPMailer directamente desde GitHub
 * Útil cuando no se puede usar Composer en el servidor
 */

echo "Instalando PHPMailer manualmente...\n\n";

// URL del repositorio de PHPMailer
$repoUrl = 'https://github.com/PHPMailer/PHPMailer/archive/refs/heads/master.zip';
$zipFile = __DIR__ . '/phpmailer.zip';
$extractDir = __DIR__ . '/PHPMailer-temp';

// Crear directorio temporal
if (!is_dir($extractDir)) {
    mkdir($extractDir, 0755, true);
}

// Descargar ZIP
echo "1. Descargando PHPMailer desde GitHub...\n";
$zipContent = @file_get_contents($repoUrl);

if ($zipContent === false) {
    echo "ERROR: No se pudo descargar PHPMailer. Verifica tu conexión a internet.\n";
    exit(1);
}

file_put_contents($zipFile, $zipContent);
echo "   ✓ Descarga completada\n\n";

// Extraer ZIP
echo "2. Extrayendo archivos...\n";
$zip = new ZipArchive();
if ($zip->open($zipFile) === TRUE) {
    $zip->extractTo($extractDir);
    $zip->close();
    echo "   ✓ Extracción completada\n\n";
} else {
    echo "ERROR: No se pudo extraer el archivo ZIP.\n";
    exit(1);
}

// Crear estructura de directorios
echo "3. Creando estructura de directorios...\n";
$vendorDir = __DIR__ . '/vendor';
$phpmailerDir = $vendorDir . '/phpmailer/phpmailer';

if (!is_dir($vendorDir)) {
    mkdir($vendorDir, 0755, true);
}
if (!is_dir($phpmailerDir)) {
    mkdir($phpmailerDir, 0755, true);
}
echo "   ✓ Directorios creados\n\n";

// Copiar archivos necesarios
echo "4. Copiando archivos de PHPMailer...\n";
$sourceDir = $extractDir . '/PHPMailer-master/src';
$files = ['PHPMailer.php', 'SMTP.php', 'Exception.php'];

foreach ($files as $file) {
    $source = $sourceDir . '/' . $file;
    $dest = $phpmailerDir . '/' . $file;
    if (file_exists($source)) {
        copy($source, $dest);
        echo "   ✓ $file copiado\n";
    }
}

// Crear autoload.php básico
echo "\n5. Creando autoload.php...\n";
$autoloadContent = <<<'PHP'
<?php
/**
 * Autoload básico para PHPMailer (instalación manual)
 */
spl_autoload_register(function ($class) {
    $prefix = 'PHPMailer\\PHPMailer\\';
    $base_dir = __DIR__ . '/phpmailer/phpmailer/';
    
    $len = strlen($prefix);
    if (strncmp($prefix, $class, $len) !== 0) {
        return;
    }
    
    $relative_class = substr($class, $len);
    $file = $base_dir . str_replace('\\', '/', $relative_class) . '.php';
    
    if (file_exists($file)) {
        require $file;
    }
});
PHP;

file_put_contents($vendorDir . '/autoload.php', $autoloadContent);
echo "   ✓ autoload.php creado\n\n";

// Limpiar archivos temporales
echo "6. Limpiando archivos temporales...\n";
if (file_exists($zipFile)) {
    unlink($zipFile);
}
if (is_dir($extractDir)) {
    deleteDirectory($extractDir);
}
echo "   ✓ Limpieza completada\n\n";

echo "✅ PHPMailer instalado correctamente!\n";
echo "   Ubicación: vendor/phpmailer/phpmailer/\n";
echo "   Autoload: vendor/autoload.php\n\n";
echo "⚠️  IMPORTANTE: Elimina este archivo (install-phpmailer.php) por seguridad.\n\n";

// Función auxiliar para eliminar directorio recursivamente
function deleteDirectory($dir) {
    if (!file_exists($dir)) {
        return true;
    }
    if (!is_dir($dir)) {
        return unlink($dir);
    }
    foreach (scandir($dir) as $item) {
        if ($item == '.' || $item == '..') {
            continue;
        }
        if (!deleteDirectory($dir . DIRECTORY_SEPARATOR . $item)) {
            return false;
        }
    }
    return rmdir($dir);
}
